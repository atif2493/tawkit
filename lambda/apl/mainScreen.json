                      "type": "Container",
                      "direction": "column",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "width": "100%",
                      "height": "100%",
                      "paddingTop": "12dp",
                      "paddingBottom": "12dp",
                      "items": [
                        { "type": "Text", "text": "🌙", "fontSize": "40dp", "textAlign": "center" },
                        {
                          "type": "Text",
