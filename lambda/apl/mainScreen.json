                          "text": "Hanafi",
                          "fontSize": "12dp",
                          "color": "${myPrayerTimeData.properties.prayers[2].status == 'past' ? '#444444' : 'rgba(255,165,0,0.7)'}",
                          "textAlign": "center",
                          "spacing": "2dp"
                        },
                        {
                          "type": "Text",
                          "when": "${myPrayerTimeData.properties.prayers[2].isNext}",
                          "text": "▶ NOW",
                          "fontSize": "15dp",
                          "fontWeight": "700",
                          "color": "#FFA500",
                          "textAlign": "center",
                          "spacing": "4dp"
                        },
                        {
                          "type": "Text",
                          "when": "${myPrayerTimeData.properties.prayers[2].status == 'past'}",
                          "text": "✓ Done",
                          "fontSize": "15dp",
                          "color": "#4A9A4A",
                          "textAlign": "center",
                          "spacing": "4dp"
                        }
                      ]
                    }
                  },

                  {
                    "type": "Frame",
                    "grow": 1,
                    "borderRadius": "18dp",
                    "backgroundColor": "${myPrayerTimeData.properties.prayers[3].isNext ? '#AA2200' : (myPrayerTimeData.properties.prayers[3].status == 'past' ? 'rgba(30,30,30,0.70)' : 'rgba(140,20,0,0.55)')}",
                    "borderWidth": "${myPrayerTimeData.properties.prayers[3].isNext ? 3 : 0}",
