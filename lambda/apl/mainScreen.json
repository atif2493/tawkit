                          "fontWeight": "700",
                          "color": "${myPrayerTimeData.properties.prayers[1].status == 'past' ? '#666666' : '#FFFFFF'}",
                          "textAlign": "center",
                          "spacing": "4dp"
                        },
                        {
                          "type": "Text",
                          "text": "${myPrayerTimeData.properties.prayers[1].nameAr}",
