                        "color": "#D4AF37",
                        "textAlign": "center",
                        "spacing": "10dp"
                      }
                    ]
                  }

                ]
              },

              {
                "type": "Container",
                "direction": "row",
                "justifyContent": "spaceAround",
                "alignItems": "stretch",
                "width": "100%",
                "height": "36vh",
                "spacing": "10dp",
                "items": [

                  {
                    "type": "Frame",
                    "grow": 1,
                    "borderRadius": "18dp",
                    "backgroundColor": "${myPrayerTimeData.properties.prayers[0].isNext ? '#7B2FBE' : (myPrayerTimeData.properties.prayers[0].status == 'past' ? 'rgba(30,30,30,0.70)' : 'rgba(80,20,140,0.55)')}",
                    "borderWidth": "${myPrayerTimeData.properties.prayers[0].isNext ? 3 : 0}",
                    "borderColor": "#BF80FF",
                    "item": {
                      "type": "Container",
                      "direction": "column",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "width": "100%",
                      "height": "100%",
                      "paddingTop": "12dp",
                      "paddingBottom": "12dp",
