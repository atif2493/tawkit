                          "fontFamily": "Noto Naskh Arabic",
                          "textAlign": "center",
                          "spacing": "2dp"
                        },
                        {
                          "type": "Text",
                          "text": "${myPrayerTimeData.properties.prayers[2].time}",
                          "fontSize": "36dp",
                          "fontWeight": "700",
                          "color": "${myPrayerTimeData.properties.prayers[2].status == 'past' ? '#555555' : '#FFE0A0'}",
                          "textAlign": "center",
                          "spacing": "8dp"
