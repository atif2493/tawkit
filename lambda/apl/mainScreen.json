{
  "type": "APL",
  "version": "2024.1",
  "theme": "dark",
  "import": [
    { "name": "alexa-layouts", "version": "1.7.0" },
    { "name": "alexa-styles", "version": "1.6.0" }
  ],
  "mainTemplate": {
    "parameters": ["myPrayerTimeData"],
    "item": {
      "type": "Frame",
      "width": "100vw",
      "height": "100vh",
      "backgroundColor": "#0A1628",
      "item": {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "items": [
          {
            "type": "AlexaBackground",
            "backgroundImageSource": "https://my-prayer-time-content-357977905088.s3.us-east-1.amazonaws.com/bg/islamic-bg-v3.jpg",
            "backgroundScale": "best-fill",
            "backgroundColor": "#0A1628",
            "colorOverlay": false,
            "overlayGradient": false
          },
          {
            "type": "Container",
            "position": "absolute",
            "left": "0",
            "top": "0",
            "width": "100vw",
            "height": "100vh",
            "direction": "column",
            "paddingLeft": "3vw",
            "paddingRight": "3vw",
            "paddingTop": "1.5vh",
            "paddingBottom": "1.5vh",
            "items": [

              {
                "type": "Container",
                "direction": "row",
                "justifyContent": "spaceBetween",
                "alignItems": "center",
                "width": "100%",
                "height": "7vh",
                "items": [
                  {
                    "type": "Container",
                    "direction": "row",
                    "alignItems": "center",
                    "items": [
                      {
                        "type": "Text",
                        "text": "☪",
                        "fontSize": "36.5dp",
                        "color": "#D4AF37"
                      },
                      {
                        "type": "Text",
                        "text": " My Prayer Time",
                        "fontSize": "38.5dp",
                        "fontWeight": "700",
                        "color": "#D4AF37",
                        "letterSpacing": "1dp"
                      }
                    ]
                  },
                  {
                    "type": "Container",
                    "direction": "column",
                    "alignItems": "end",
                    "items": [
                      {
                        "type": "Container",
                        "direction": "row",
                        "alignItems": "center",
                        "items": [
                          {
                            "type": "Text",
                            "text": "${myPrayerTimeData.properties.moonPhase}",
                            "fontSize": "30.5dp"
                          },
                          {
                            "type": "Text",
                            "text": " ${myPrayerTimeData.properties.hijriDateEn}",
                            "fontSize": "22.5dp",
                            "fontWeight": "600",
                            "color": "#D4AF37"
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "text": "${myPrayerTimeData.properties.cityName} · ${myPrayerTimeData.properties.madhab}",
                        "fontSize": "16.5dp",
                        "color": "rgba(0,0,0,0.6)"
                      }
                    ]
                  }
                ]
              },

              {
                "type": "Frame",
                "width": "100%",
                "height": "1dp",
                "backgroundColor": "rgba(212,175,55,0.3)"
              },

              {
                "type": "Container",
                "when": "${myPrayerTimeData.properties.isRamadan}",
                "direction": "row",
                "justifyContent": "center",
                "alignItems": "center",
                "width": "100%",
                "height": "5vh",
                "spacing": "4dp",
                "items": [
                  {
                    "type": "Frame",
                    "borderRadius": "20dp",
                    "backgroundColor": "rgba(212,175,55,0.15)",
                    "borderWidth": "1",
                    "borderColor": "rgba(212,175,55,0.3)",
                    "paddingLeft": "20dp",
                    "paddingRight": "20dp",
                    "paddingTop": "4dp",
                    "paddingBottom": "4dp",
                    "item": {
                      "type": "Container",
                      "direction": "row",
                      "alignItems": "center",
                      "items": [
                        {
                          "type": "Text",
                          "text": "🌙 ${myPrayerTimeData.properties.ramadanText}",
                          "fontSize": "18.5dp",
                          "fontWeight": "700",
                          "color": "#111111"
                        },
                        {
                          "type": "Text",
                          "text": "  ·  ${myPrayerTimeData.properties.eidCountdown} (${myPrayerTimeData.properties.eidEstDate})",
                          "fontSize": "16.5dp",
                          "color": "rgba(0,0,0,0.6)"
                        }
                      ]
                    }
                  }
                ]
              },

              {
                "type": "Container",
                "direction": "row",
                "justifyContent": "spaceBetween",
                "alignItems": "center",
                "width": "100%",
                "grow": 1,
                "items": [

                  {
                    "type": "Container",
                    "direction": "column",
                    "alignItems": "center",
                    "justifyContent": "center",
                    "grow": 1,
                    "items": [
                      {
                        "type": "Text",
                        "text": "${myPrayerTimeData.properties.currentTime}",
                        "fontSize": "102.5dp",
                        "fontWeight": "200",
                        "color": "#111111",
                        "textAlign": "center",
                        "letterSpacing": "2dp"
                      },
                      {
                        "type": "Text",
                        "text": "${myPrayerTimeData.properties.gregorianDate}",
                        "fontSize": "24.5dp",
                        "color": "rgba(0,0,0,0.5)",
                        "textAlign": "center",
                        "spacing": "4dp"
                      }
                    ]
                  },

                  {
                    "type": "Container",
                    "direction": "column",
                    "alignItems": "center",
                    "justifyContent": "center",
                    "width": "24vw",
                    "items": [
                      {
                        "type": "Frame",
                        "width": "170dp",
                        "height": "170dp",
                        "borderRadius": "85dp",
                        "backgroundColor": "rgba(212,175,55,0.15)",
                        "borderWidth": "3",
                        "borderColor": "#D4AF37",
                        "item": {
                          "type": "Container",
                          "alignItems": "center",
                          "justifyContent": "center",
                          "direction": "column",
                          "width": "100%",
                          "height": "100%",
                          "items": [
                            {
                              "type": "Text",
                              "text": "${myPrayerTimeData.properties.nextPrayer.nameEn}",
                              "fontSize": "26.5dp",
                              "fontWeight": "700",
                              "color": "#D4AF37"
                            },
                            {
                              "type": "Text",
                              "text": "━━━",
                              "fontSize": "18.5dp",
                              "color": "rgba(0,0,0,0.25)"
                            },
                            {
                              "type": "Text",
                              "text": "${myPrayerTimeData.properties.nextPrayer.countdown}",
                              "fontSize": "36.5dp",
                              "fontWeight": "700",
                              "color": "#111111"
                            }
                          ]
                        }
                      },
                      {
                        "type": "Text",
                        "text": "at ${myPrayerTimeData.properties.nextPrayer.time}",
                        "fontSize": "18.5dp",
                        "fontWeight": "600",
                        "color": "#D4AF37",
                        "textAlign": "center",
                        "spacing": "8dp"
                      }
                    ]
                  }
                ]
              },

              {
                "type": "Container",
                "direction": "row",
                "justifyContent": "spaceEvenly",
                "alignItems": "stretch",
                "width": "100%",
                "height": "36vh",
                "items": [

                  {
                    "type": "Frame",
                    "grow": 1,
                    "borderRadius": "14dp",
                    "backgroundColor": "${myPrayerTimeData.properties.prayers[0].isNext ? 'rgba(212,175,55,0.2)' : 'rgba(255,255,255,0.35)'}",
                    "borderWidth": "${myPrayerTimeData.properties.prayers[0].isNext ? '2' : '1'}",
                    "borderColor": "${myPrayerTimeData.properties.prayers[0].isNext ? '#D4AF37' : 'rgba(0,0,0,0.1)'}",
                    "marginRight": "6dp",
                    "item": {
                      "type": "Container",
                      "direction": "column",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "width": "100%",
                      "height": "100%",
                      "items": [
                        { "type": "Text", "text": "🌅", "fontSize": "28dp" },
                        { "type": "Text", "text": "Fajr", "fontSize": "22dp", "fontWeight": "700", "color": "${myPrayerTimeData.properties.prayers[0].isNext ? '#D4AF37' : '#FFFFFF'}", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.prayers[0].time}", "fontSize": "24dp", "fontWeight": "700", "color": "${myPrayerTimeData.properties.prayers[0].isNext ? '#D4AF37' : '#111111'}", "spacing": "4dp" },
                        { "type": "Text", "text": "Iqama", "fontSize": "13dp", "color": "rgba(0,0,0,0.5)", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.prayers[0].iqama}", "fontSize": "20dp", "fontWeight": "700", "color": "#0d7039", "spacing": "2dp" }
                      ]
                    }
                  },

                  {
                    "type": "Frame",
                    "grow": 1,
                    "borderRadius": "14dp",
                    "backgroundColor": "${myPrayerTimeData.properties.prayers[1].isNext ? 'rgba(212,175,55,0.2)' : 'rgba(255,255,255,0.35)'}",
                    "borderWidth": "${myPrayerTimeData.properties.prayers[1].isNext ? '2' : '1'}",
                    "borderColor": "${myPrayerTimeData.properties.prayers[1].isNext ? '#D4AF37' : 'rgba(0,0,0,0.1)'}",
                    "marginRight": "6dp",
                    "item": {
                      "type": "Container",
                      "direction": "column",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "width": "100%",
                      "height": "100%",
                      "items": [
                        { "type": "Text", "text": "☀️", "fontSize": "28dp" },
                        { "type": "Text", "text": "Dhuhr", "fontSize": "22dp", "fontWeight": "700", "color": "${myPrayerTimeData.properties.prayers[1].isNext ? '#D4AF37' : '#FFFFFF'}", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.prayers[1].time}", "fontSize": "24dp", "fontWeight": "700", "color": "${myPrayerTimeData.properties.prayers[1].isNext ? '#D4AF37' : '#111111'}", "spacing": "4dp" },
                        { "type": "Text", "text": "Iqama", "fontSize": "13dp", "color": "rgba(0,0,0,0.5)", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.prayers[1].iqama}", "fontSize": "20dp", "fontWeight": "700", "color": "#0d7039", "spacing": "2dp" }
                      ]
                    }
                  },

                  {
                    "type": "Frame",
                    "grow": 1,
                    "borderRadius": "14dp",
                    "backgroundColor": "${myPrayerTimeData.properties.prayers[2].isNext ? 'rgba(212,175,55,0.2)' : 'rgba(255,255,255,0.35)'}",
                    "borderWidth": "${myPrayerTimeData.properties.prayers[2].isNext ? '2' : '1'}",
                    "borderColor": "${myPrayerTimeData.properties.prayers[2].isNext ? '#D4AF37' : 'rgba(0,0,0,0.1)'}",
                    "marginRight": "6dp",
                    "item": {
                      "type": "Container",
                      "direction": "column",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "width": "100%",
                      "height": "100%",
                      "items": [
                        { "type": "Text", "text": "🌤", "fontSize": "28dp" },
                        { "type": "Text", "text": "Asr", "fontSize": "22dp", "fontWeight": "700", "color": "${myPrayerTimeData.properties.prayers[2].isNext ? '#D4AF37' : '#FFFFFF'}", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.prayers[2].time}", "fontSize": "24dp", "fontWeight": "700", "color": "${myPrayerTimeData.properties.prayers[2].isNext ? '#D4AF37' : '#111111'}", "spacing": "4dp" },
                        { "type": "Text", "text": "Iqama", "fontSize": "13dp", "color": "rgba(0,0,0,0.5)", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.prayers[2].iqama}", "fontSize": "20dp", "fontWeight": "700", "color": "#0d7039", "spacing": "2dp" }
                      ]
                    }
                  },

                  {
                    "type": "Frame",
                    "grow": 1,
                    "borderRadius": "14dp",
                    "backgroundColor": "${myPrayerTimeData.properties.prayers[3].isNext ? 'rgba(212,175,55,0.2)' : 'rgba(255,255,255,0.35)'}",
                    "borderWidth": "${myPrayerTimeData.properties.prayers[3].isNext ? '2' : '1'}",
                    "borderColor": "${myPrayerTimeData.properties.prayers[3].isNext ? '#D4AF37' : 'rgba(0,0,0,0.1)'}",
                    "marginRight": "6dp",
                    "item": {
                      "type": "Container",
                      "direction": "column",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "width": "100%",
                      "height": "100%",
                      "items": [
                        { "type": "Text", "text": "🌇", "fontSize": "28dp" },
                        { "type": "Text", "text": "Maghrib", "fontSize": "22dp", "fontWeight": "700", "color": "${myPrayerTimeData.properties.prayers[3].isNext ? '#D4AF37' : '#FFFFFF'}", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.prayers[3].time}", "fontSize": "24dp", "fontWeight": "700", "color": "${myPrayerTimeData.properties.prayers[3].isNext ? '#D4AF37' : '#111111'}", "spacing": "4dp" },
                        { "type": "Text", "text": "Iqama", "fontSize": "13dp", "color": "rgba(0,0,0,0.5)", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.prayers[3].iqama}", "fontSize": "20dp", "fontWeight": "700", "color": "#0d7039", "spacing": "2dp" }
                      ]
                    }
                  },

                  {
                    "type": "Frame",
                    "grow": 1,
                    "borderRadius": "14dp",
                    "backgroundColor": "${myPrayerTimeData.properties.prayers[4].isNext ? 'rgba(212,175,55,0.2)' : 'rgba(255,255,255,0.35)'}",
                    "borderWidth": "${myPrayerTimeData.properties.prayers[4].isNext ? '2' : '1'}",
                    "borderColor": "${myPrayerTimeData.properties.prayers[4].isNext ? '#D4AF37' : 'rgba(0,0,0,0.1)'}",
                    "marginRight": "6dp",
                    "item": {
                      "type": "Container",
                      "direction": "column",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "width": "100%",
                      "height": "100%",
                      "items": [
                        { "type": "Text", "text": "🌙", "fontSize": "28dp" },
                        { "type": "Text", "text": "Eaisha", "fontSize": "22dp", "fontWeight": "700", "color": "${myPrayerTimeData.properties.prayers[4].isNext ? '#D4AF37' : '#FFFFFF'}", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.prayers[4].time}", "fontSize": "24dp", "fontWeight": "700", "color": "${myPrayerTimeData.properties.prayers[4].isNext ? '#D4AF37' : '#111111'}", "spacing": "4dp" },
                        { "type": "Text", "text": "Iqama", "fontSize": "13dp", "color": "rgba(0,0,0,0.5)", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.prayers[4].iqama}", "fontSize": "20dp", "fontWeight": "700", "color": "#0d7039", "spacing": "2dp" }
                      ]
                    }
                  },

                  {
                    "type": "Frame",
                    "when": "${myPrayerTimeData.properties.isFriday}",
                    "grow": 1,
                    "borderRadius": "14dp",
                    "backgroundColor": "rgba(13,112,57,0.2)",
                    "borderWidth": "2",
                    "borderColor": "#0d7039",
                    "item": {
                      "type": "Container",
                      "direction": "column",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "width": "100%",
                      "height": "100%",
                      "items": [
                        { "type": "Text", "text": "🕌", "fontSize": "28dp" },
                        { "type": "Text", "text": "Jumuah", "fontSize": "22dp", "fontWeight": "700", "color": "#0d7039", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.jumuah1}", "fontSize": "20dp", "fontWeight": "700", "color": "#111111", "spacing": "4dp" },
                        { "type": "Text", "text": "2nd", "fontSize": "13dp", "color": "rgba(0,0,0,0.5)", "spacing": "4dp" },
                        { "type": "Text", "text": "${myPrayerTimeData.properties.jumuah2}", "fontSize": "20dp", "fontWeight": "700", "color": "#111111", "spacing": "2dp" }
                      ]
                    }
                  }

                ]
              }

            ]
          }
        ]
      }
    }
  }
}
