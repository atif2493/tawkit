                          "fontFamily": "Noto Naskh Arabic",
                          "textAlign": "center",
                          "spacing": "2dp"
                        },
                        {
                          "type": "Text",
                          "text": "${myPrayerTimeData.properties.prayers[3].time}",
                          "fontSize": "36dp",
                          "fontWeight": "700",
                          "color": "${myPrayerTimeData.properties.prayers[3].status == 'past' ? '#555555' : '#FFD0C0'}",
                          "textAlign": "center",
                          "spacing": "8dp"
                        },
                        {
                          "type": "Text",
                          "when": "${myPrayerTimeData.properties.prayers[3].isNext}",
                          "text": "▶ NOW",
                          "fontSize": "15dp",
                          "fontWeight": "700",
                          "color": "#FF6B4A",
                          "textAlign": "center",
                          "spacing": "4dp"
                        },
                        {
                          "type": "Text",
                          "when": "${myPrayerTimeData.properties.prayers[3].status == 'past'}",
