                        {
                          "type": "Text",
                          "text": "${myPrayerTimeData.properties.prayers[0].nameEn}",
                          "fontSize": "34dp",
                          "fontWeight": "700",
                          "color": "${myPrayerTimeData.properties.prayers[0].status == 'past' ? '#666666' : '#FFFFFF'}",
                          "textAlign": "center",
                          "spacing": "4dp"
                        },
                        {
                          "type": "Text",
                          "text": "${myPrayerTimeData.properties.prayers[0].nameAr}",
                          "fontSize": "16dp",
                          "color": "${myPrayerTimeData.properties.prayers[0].status == 'past' ? '#444444' : '#BF80FF'}",
                          "fontFamily": "Noto Naskh Arabic",
                          "textAlign": "center",
                          "spacing": "2dp"
                        },
                        {
                          "type": "Text",
                          "text": "${myPrayerTimeData.properties.prayers[0].time}",
                          "fontSize": "36dp",
                          "fontWeight": "700",
                          "color": "${myPrayerTimeData.properties.prayers[0].status == 'past' ? '#555555' : '#E8D0FF'}",
                          "textAlign": "center",
                          "spacing": "8dp"
                        },
                        {
                          "type": "Text",
                          "when": "${myPrayerTimeData.properties.prayers[0].isNext}",
                          "text": "▶ NOW",
                          "fontSize": "15dp",
                          "fontWeight": "700",
                          "color": "#BF80FF",
                          "textAlign": "center",
                          "spacing": "4dp"
                        },
                        {
                          "type": "Text",
                          "when": "${myPrayerTimeData.properties.prayers[0].status == 'past'}",
                          "text": "✓ Done",
                          "fontSize": "15dp",
                          "color": "#4A9A4A",
                          "textAlign": "center",
                          "spacing": "4dp"
