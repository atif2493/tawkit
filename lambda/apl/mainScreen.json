{
  "type": "APL",
  "version": "2024.1",
  "theme": "dark",
  "import": [
    { "name": "alexa-layouts", "version": "1.7.0" },
    { "name": "alexa-styles", "version": "1.6.0" }
  ],
  "resources": [],
  "layouts": {},
  "mainTemplate": {
    "parameters": ["myPrayerTimeData"],
    "item": {
      "type": "Frame",
      "width": "100vw",
      "height": "100vh",
      "backgroundColor": "black",
      "item": {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "direction": "column",
        "items": [

          {
            "type": "AlexaBackground",
            "backgroundImageSource": "https://my-prayer-time-content-357977905088.s3.us-east-1.amazonaws.com/bg/islamic-pattern.jpg",
            "backgroundScale": "best-fill",
            "backgroundColor": "black",
            "colorOverlay": false,
            "overlayGradient": false
          },

          {
            "type": "Container",
            "position": "absolute",
            "left": "0",
            "top": "0",
            "width": "100vw",
            "height": "100vh",
            "direction": "column",
            "paddingLeft": "4vw",
            "paddingRight": "4vw",
            "paddingTop": "2vh",
            "paddingBottom": "2vh",
            "items": [

              {
                "type": "Container",
                "direction": "row",
                "justifyContent": "spaceBetween",
                "alignItems": "center",
                "width": "100%",
                "height": "8vh",
                "items": [
                  {
                    "type": "Text",
                    "text": "My Prayer Time",
                    "fontSize": "28dp",
                    "fontWeight": "700",
                    "color": "#4ECDC4"
                  },
                  {
                    "type": "Text",
                    "text": "${myPrayerTimeData.properties.cityName} · ${myPrayerTimeData.properties.madhab}",
                    "fontSize": "20dp",
                    "color": "#AAAAAA"
                  }
                ]
              },

              {
                "type": "Container",
                "direction": "row",
                "justifyContent": "spaceBetween",
                "alignItems": "center",
                "width": "100%",
                "grow": 1,
                "items": [

                  {
                    "type": "Container",
                    "direction": "column",
                    "alignItems": "center",
                    "justifyContent": "center",
                    "grow": 1,
                    "items": [
                      {
                        "type": "Frame",
                        "borderRadius": "20dp",
                        "backgroundColor": "rgba(0,0,0,0.55)",
                        "borderWidth": "1",
                        "borderColor": "rgba(255,255,255,0.12)",
                        "paddingLeft": "40dp",
                        "paddingRight": "40dp",
                        "paddingTop": "18dp",
                        "paddingBottom": "18dp",
                        "item": {
                          "type": "Container",
                          "direction": "column",
                          "alignItems": "center",
                          "items": [
                            {
                              "type": "Text",
                              "text": "${myPrayerTimeData.properties.currentTime}",
                              "fontSize": "110dp",
                              "fontWeight": "300",
                              "color": "#FFFFFF",
                              "textAlign": "center",
                              "letterSpacing": "-2dp"
                            },
                            {
                              "type": "Text",
                              "text": "${myPrayerTimeData.properties.hijriDateEn}  |  ${myPrayerTimeData.properties.gregorianDate}",
                              "fontSize": "24dp",
                              "fontWeight": "400",
                              "color": "#CCCCCC",
                              "textAlign": "center",
                              "spacing": "6dp"
                            }
                          ]
                        }
                      }
                    ]
                  },

                  {
                    "type": "Container",
                    "direction": "column",
                    "alignItems": "center",
                    "justifyContent": "center",
                    "width": "22vw",
                    "paddingLeft": "16dp",
                    "items": [
                      {
                        "type": "Frame",
                        "width": "160dp",
                        "height": "160dp",
                        "borderRadius": "80dp",
                        "backgroundColor": "${myPrayerTimeData.properties.nextPrayer.countdownColor}",
                        "borderWidth": "5",
                        "borderColor": "rgba(255,255,255,0.3)",
                        "item": {
                          "type": "Container",
                          "direction": "column",
                          "alignItems": "center",
                          "justifyContent": "center",
                          "width": "100%",
                          "height": "100%",
                          "items": [
                            {
                              "type": "Text",
                              "text": "${myPrayerTimeData.properties.nextPrayer.nameEn}",
                              "fontSize": "22dp",
                              "fontWeight": "700",
                              "color": "#FFFFFF",
                              "textAlign": "center"
                            },
                            {
                              "type": "Text",
                              "text": "NEXT IN",
                              "fontSize": "14dp",
                              "color": "rgba(255,255,255,0.75)",
                              "textAlign": "center",
                              "spacing": "2dp"
                            },
                            {
                              "type": "Text",
                              "text": "${myPrayerTimeData.properties.nextPrayer.countdown}",
                              "fontSize": "30dp",
                              "fontWeight": "700",
                              "color": "#FFFFFF",
                              "textAlign": "center",
                              "spacing": "2dp"
