{
  "manifest": {
    "publishingInformation": {
      "locales": {
        "en-US": {
          "name": "My Prayer Time Prayer Times",
          "summary": "Islamic prayer times display for Echo Show with Hanafi Asr",
          "description": "My Prayer Time displays the 5 daily Islamic prayer times for Apex, NC on your Echo Show screen. Features a countdown to the next prayer, Adhan audio at prayer times, and rotating Hadiths and Quran verses. Uses Hanafi madhab for Asr calculation.",
          "examplePhrases": [
            "Alexa, open My Prayer Time",
            "Alexa, ask My Prayer Time for prayer times",
            "Alexa, ask My Prayer Time what is the next prayer"
          ],
          "keywords": ["prayer", "salah", "islam", "muslim", "adhan", "fajr", "isha", "prayer times", "mosque", "quran", "hadith", "hanafi"]
        }
      },
      "isAvailableWorldwide": true,
      "testingInstructions": "Open the skill and check that prayer times display correctly on Echo Show.",
      "category": "RELIGION_AND_SPIRITUALITY",
      "distributionCountries": ["US", "CA", "GB"]
    },
    "apis": {
      "custom": {
        "endpoint": {
          "sourceDir": "lambda"
        },
        "interfaces": [
          {
            "type": "ALEXA_PRESENTATION_APL",
            "supportedViewports": [
              {
                "mode": "HUB",
                "shape": "RECTANGLE",
                "minWidth": 100,
                "maxWidth": 1280,
                "minHeight": 100,
                "maxHeight": 800
              }
            ]
          }
        ]
      }
    },
    "manifestVersion": "1.0",
    "permissions": [
      {
        "name": "alexa::alerts:reminders:skill:readwrite"
      },
      {
        "name": "alexa::devices:all:address:full:read"
      }
    ],
    "privacyAndCompliance": {
      "allowsPurchases": false,
      "usesPersonalInfo": true,
      "isChildDirected": false,
      "isExportCompliant": true,
      "containsAds": false,
      "usesHealthInfo": false
    }
  }
}
